// This is your Prisma schema file
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         Int      @id @default(autoincrement())
  email      String   @unique
  password   String
  name       String?
  role       String   @default("admin")
  created_at DateTime @default(now())

  @@map("users")
}

model Vehicle {
  id                 Int           @id @default(autoincrement())
  name               String
  passenger_capacity Int
  luggage_capacity   Int
  price              Float         @default(0)
  image_url          String?
  status             String        @default("active") // active / passive
  created_at         DateTime      @default(now())
  reservations       Reservation[]

  @@map("vehicles")
}

model Reservation {
  id               Int      @id @default(autoincrement())
  reference        String   @unique
  customer_name    String
  email            String
  phone            String
  pickup_location  String
  dropoff_location String
  date             String
  passengers       Int      @default(1)
  luggage          Int      @default(0)
  flight_number    String?
  notes            String?
  vehicle_id       Int?
  vehicle          Vehicle? @relation(fields: [vehicle_id], references: [id])
  status           String   @default("pending") // pending / approved / cancelled
  payment_method   String?  @default("cash") // cash / card
  price            Float?
  source           String?  @default("website")
  created_at       DateTime @default(now())

  @@map("reservations")
}

model CustomerTracking {
  id           Int      @id @default(autoincrement())
  session_id   String
  current_step String   // homepage / vehicle_selected / form_filled / completed
  last_action  String?
  metadata     String?  // JSON string for extra data
  ip_address   String?
  user_agent   String?
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  @@map("customer_tracking")
}

model Tour {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  duration    String   // e.g. "5 hours"
  max_people  Int
  km_limit    Int?
  price       Float
  status      String   @default("active") // active / passive
  image_url   String?
  created_at  DateTime @default(now())

  @@map("tours")
}

model Blog {
  id         Int      @id @default(autoincrement())
  title      String
  slug       String   @unique
  content    String
  excerpt    String?
  image_url  String?
  status     String   @default("active") // active / passive
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("blog")
}

model Faq {
  id         Int      @id @default(autoincrement())
  question   String
  answer     String
  order_num  Int      @default(0)
  created_at DateTime @default(now())

  @@map("faq")
}

model Page {
  id         Int      @id @default(autoincrement())
  page_name  String   @unique // about, contact, etc.
  title      String?
  content    String
  updated_at DateTime @updatedAt

  @@map("pages")
}

model ContactMessage {
  id         Int      @id @default(autoincrement())
  name       String
  email      String
  phone      String?
  subject    String?
  message    String
  status     String   @default("unread") // unread / read
  source     String?
  created_at DateTime @default(now())

  @@map("contact_messages")
}

model DriverApplication {
  id         Int      @id @default(autoincrement())
  // Personal Info
  full_name  String
  email      String
  phone      String
  status     String   @default("pending") // pending / approved / rejected

  // Documents (base64 or URL stored as text)
  photo           String?  // vesikalık
  id_front        String?  // kimlik ön
  id_back         String?  // kimlik arka
  license_front   String?  // ehliyet ön
  license_back    String?  // ehliyet arka
  criminal_record String?  // sabıka kaydı
  residence_doc   String?  // ikametgah
  tursab_doc      String?  // TÜRSAB belgesi
  d2_doc          String?  // D2 yetki belgesi

  // Bank Info
  bank_name       String?
  bank_holder     String?
  bank_iban       String?

  // Vehicle Photos
  car_front       String?
  car_right       String?
  car_left        String?
  car_back        String?
  car_interior_1  String?
  car_interior_2  String?
  car_interior_3  String?
  car_interior_4  String?

  // Admin notes
  admin_notes     String?
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  @@map("driver_applications")
}

model Driver {
  id         Int      @id @default(autoincrement())
  email      String   @unique
  password   String
  name       String
  phone      String?
  status     String   @default("active")
  application_id Int?
  created_at DateTime @default(now())

  @@map("drivers")
}
