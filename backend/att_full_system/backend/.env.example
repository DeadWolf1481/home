# Database - Railway / Supabase / Neon PostgreSQL URL
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME"

# JWT Secret - change this to a long random string
JWT_SECRET="att-super-secret-jwt-key-2026-change-this"

# Port
PORT=3001

# Frontend URL for CORS (your Vercel domain)
FRONTEND_URL="https://airportstransferturkey.com"

# Environment
NODE_ENV="production"
